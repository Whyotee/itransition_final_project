generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  githubId  String?  @unique 
  googleId  String?  @unique 
  email     String? 
  name      String
  avatarUrl String? 
  createdAt DateTime @default(now())

  profileValues ProfileValue[]
  positions     Position[] 
}

enum AttributeType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
}

enum AttributeCategory {
  CERTIFICATION
  DOMAIN_KNOWLEDGE
  PERSONAL_INFORMATION
  SOFT_SKILLS
}

model Attribute {
  id        Int               @id @default(autoincrement())
  name      String            @unique 
  type      AttributeType     @default(TEXT)
  category  AttributeCategory @default(PERSONAL_INFORMATION)
  isBuiltIn Boolean           @default(false) 
  createdAt DateTime          @default(now())

  profileValues ProfileValue[]
}

model ProfileValue {
  id          Int    @id @default(autoincrement())
  userId      Int
  attributeId Int
  value       String

  user      User      @relation(fields: [userId], references: [id])
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade) // deleting an attribute removes its saved values

  @@unique([userId, attributeId])
}

model Position {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}
